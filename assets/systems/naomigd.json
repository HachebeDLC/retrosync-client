            "is_retroachievements_compatible": true,
            "platforms": {
                "android": {
                    "launch_arguments": "-n com.retroarch/com.retroarch.browser.retroactivity.RetroActivityFuture --es ROM \"{file.path}\" --es LIBRETRO \"flycast\" --es CONFIGFILE \"/storage/emulated/0/Android/data/com.retroarch/files/retroarch.cfg\""
                },
                "windows": {
                    "executable": "retroarch.exe",
                    "args": "-L flycast_libretro.dll \"{file.path}\""
                },
