            "description": "Supported extensions: 7z, chd, dat, lst, zip.",
            "is_retroachievements_compatible": true,
            "platforms": {
                "android": {
                    "launch_arguments": "-n com.retroarch.aarch64/com.retroarch.browser.retroactivity.RetroActivityFuture --es ROM \"{file.path}\" --es LIBRETRO \"flycast\" --es CONFIGFILE \"/storage/emulated/0/Android/data/com.retroarch.aarch64/files/retroarch.cfg\""
                }
            }
        },
        {
            "name": "RetroArch32 Flycast",
