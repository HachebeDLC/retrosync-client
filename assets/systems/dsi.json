            "unique_id": "dsi.ra.melonds",
            "is_retroachievements_compatible": true,
            "description": "MelonDS core for RetroArch.",
            "platforms": {
                "android": {
                    "launch_arguments": "-n com.retroarch/com.retroarch.browser.retroactivity.RetroActivityFuture --es ROM \"{file.path}\" --es LIBRETRO \"melonds\" --es CONFIGFILE \"/storage/emulated/0/Android/data/com.retroarch/files/retroarch.cfg\""
                },
                "windows": {
                    "executable": "retroarch.exe",
                    "args": "-L melonds_libretro.dll \"{file.path}\""
                },
                "linux": {
                    "executable": "retroarch",
                    "args": "-L melonds_libretro.so \"{file.path}\""
                },
