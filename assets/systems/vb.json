            "unique_id": "virtualboy.com.simongellis.vvb",
            "description": "Supported extensions: vb, zip.",
            "is_retroachievements_compatible": false,
            "platforms": {
                "android": {
                    "launch_arguments": "-n com.simongellis.vvb/com.simongellis.vvb.MainActivity -a android.intent.action.VIEW -d {file.uri}"
                }
            }
        },
        {
            "name": "RetroArch64 Beetle VB",
            "unique_id": "virtualboy.ra64.mednafen_vb",
            "description": "Supported extensions: bin, vb, vboy.",
            "is_retroachievements_compatible": true,
            "platforms": {
                "android": {
                    "launch_arguments": "-n com.retroarch.aarch64/com.retroarch.browser.retroactivity.RetroActivityFuture --es ROM \"{file.path}\" --es LIBRETRO \"mednafen_vb\" --es CONFIGFILE \"/storage/emulated/0/Android/data/com.retroarch.aarch64/files/retroarch.cfg\""
                }
            }
        },
        {
            "name": "RetroArch32 Beetle VB",
            "unique_id": "virtualboy.ra32.mednafen_vb",
