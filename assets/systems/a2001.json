            "description": "Supported extensions: bin, zip.",
            "platforms": {
                "android": {
                    "launch_arguments": "-n com.retroarch/com.retroarch.browser.retroactivity.RetroActivityFuture --es ROM \"{file.path}\" --es LIBRETRO \"mamemess\" --es CONFIGFILE \"/storage/emulated/0/Android/data/com.retroarch/files/retroarch.cfg\""
                },
                "windows": {
                    "executable": "retroarch.exe",
                    "args": "-L mamemess_libretro.dll \"{file.path}\""
                },
                "linux": {
