            "unique_id": "fbneo.ra.fbneo",
            "description": "Supported extensions: 7z, ccd, cue, zip.",
            "is_retroachievements_compatible": true,
            "platforms": {
                "android": {
                    "launch_arguments": "-n com.retroarch/com.retroarch.browser.retroactivity.RetroActivityFuture --es ROM \"{file.path}\" --es LIBRETRO \"fbneo\" --es CONFIGFILE \"/storage/emulated/0/Android/data/com.retroarch/files/retroarch.cfg\""
                },
                "windows": {
                    "executable": "retroarch.exe",
                    "args": "-L fbneo_libretro.dll \"{file.path}\""
                },
                "linux": {
                    "executable": "retroarch",
                    "args": "-L fbneo_libretro.so \"{file.path}\""
                },
